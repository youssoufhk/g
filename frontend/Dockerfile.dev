# Gamma frontend dev image.
#
# Used only by infra/docker/docker-compose.dev.yml. Source is bind-mounted
# at runtime so file edits hot-reload via Next.js dev server.
#
# Production images are built separately by the deploy track (section 16
# of EXECUTION_CHECKLIST.md).

# syntax=docker/dockerfile:1.7
FROM node:22-alpine

WORKDIR /app

# Install deps in a layer that depends only on package.json. node_modules
# is a named/anonymous volume in compose so it does not shadow host state.
COPY package.json ./
RUN npm install --loglevel=error

EXPOSE 3000

# Node-based healthcheck: uses the built-in http module (always present)
# instead of busybox wget. 180s start period accommodates Next.js's cold
# compile on first boot under a WSL2 bind mount.
HEALTHCHECK --interval=10s --timeout=5s --start-period=180s --retries=10 \
  CMD node -e "require('http').get('http://127.0.0.1:3000', (r) => process.exit(r.statusCode < 500 ? 0 : 1)).on('error', () => process.exit(1))" || exit 1

CMD ["npm", "run", "dev"]
