# Gamma backend dev environment.
#
# Copy to .env and fill in. .env is gitignored. Never commit secrets.
# Reference: docs/runbooks/secrets-management.md

APP_ENV=dev
APP_NAME=gamma
LOG_LEVEL=info

# Database (matches infra/docker/docker-compose.dev.yml defaults)
DATABASE_URL=postgresql+asyncpg://gamma:gamma_dev_password@localhost:5432/gamma_dev

# Redis (Celery + cache + rate limit + WebSocket fanout)
REDIS_URL=redis://localhost:6379/0

# JWT signing key (dev-only, rotate in production via GCP Secret Manager)
JWT_SECRET_KEY=dev-only-not-a-real-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# CORS for the local frontend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Mailhog (matches infra/docker/docker-compose.dev.yml)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@gamma.local

# Vendor wrapper selection (stub for dev, real for staging/prod)
AI_BACKEND=mock
BLOB_BACKEND=local
EMAIL_BACKEND=mailhog
OCR_BACKEND=mock
TELEMETRY_BACKEND=stdout

# Local blob storage root (LocalFilesystemBlobStorage)
LOCAL_BLOB_ROOT=./tmp/dev-blobs
