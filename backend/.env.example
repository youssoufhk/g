# Gamma backend dev environment.
#
# Copy to .env and fill in. .env is gitignored. Never commit secrets.
# Reference: docs/runbooks/secrets-management.md
#
# Note: when the backend runs as a compose service (make dev-up), these
# defaults are overridden by the env block in infra/docker/docker-compose.dev.yml.
# This file is for running uvicorn directly on the host via the local venv.

APP_ENV=dev
APP_NAME=gamma
LOG_LEVEL=info

# Database (matches infra/docker/docker-compose.dev.yml; host path uses localhost)
DATABASE_URL=postgresql+asyncpg://gamma:gamma_dev_password@localhost:5432/gamma_dev

# Redis (Celery + cache + rate limit + WebSocket fanout)
REDIS_URL=redis://localhost:6379/0

# JWT signing key (dev-only, rotate via GCP Secret Manager in §16 Deploy Track)
JWT_SECRET_KEY=dev-only-not-a-real-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# CORS for the local frontend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Mailpit (matches infra/docker/docker-compose.dev.yml)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@gamma.local

# Vendor wrapper selection (stub for dev, real for staging/prod)
AI_BACKEND=ollama
BLOB_BACKEND=local
EMAIL_BACKEND=mailpit
OCR_BACKEND=mock
TELEMETRY_BACKEND=stdout

# Ollama (self-hosted LLM). Gemma 3 is the default; override with
# OLLAMA_MODEL=gemma4 (or whatever) if you have a newer model pulled.
# From inside a container use host.docker.internal; from the host use localhost.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3
OLLAMA_TIMEOUT_SECONDS=120

# Local blob storage root (LocalFilesystemBlobStorage)
LOCAL_BLOB_ROOT=./tmp/dev-blobs
