# Gamma ops library - environment configuration
#
# Copy to .env and fill in values. Never commit .env.
# Authentication relies on Application Default Credentials (ADC). Run:
#   gcloud auth application-default login
# before using any GCP command. This file only holds non-secret identifiers
# and the Cloudflare API token.

# Which GCP project operations target by default.
# Use gamma-staging for day-to-day work, gamma-prod only with explicit intent.
GCP_PROJECT_ID=gamma-staging

# GCP region for all regional resources. Locked to europe-west9 (Paris) by
# Org Policy constraints/gcp.resourceLocations. europe-west1 is the only
# approved backup-only region.
GCP_REGION=europe-west9

# Billing account ID used when create_project links billing. Format: 0X0X0X-0X0X0X-0X0X0X
# Leave blank if you only manage existing projects.
GCP_BILLING_ACCOUNT_ID=

# Cloudflare API token with Zone:DNS:Edit, Zone:WAF:Edit, Account:Access:Edit
# permissions on the gammahr.com zone. Generate a scoped token, not a global key.
CLOUDFLARE_API_TOKEN=

# Cloudflare zone ID for the gammahr.com zone.
CLOUDFLARE_ZONE_ID=

# Environment label used for tagging and label enforcement. Allowed: dev, staging, prod.
GAMMA_ENV=staging

# Log level. DEBUG for troubleshooting, INFO for normal use, WARNING for quiet runs.
LOG_LEVEL=INFO
